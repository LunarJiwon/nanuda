# Optional override for the SITE_ORIGIN param used by verifyEmailToken's post-verification
# redirect (see src/index.ts). It already has a sane default (the Firebase Hosting default
# domain), so you only need this if you add a custom domain to Hosting later.
#
# Copy to `.env` (applies to all deploys) or `.env.<project-id>` (applies to one project only),
# uncomment, and fill in — see https://firebase.google.com/docs/functions/config-env for the
# lookup order. This is a plain, non-secret value; RESEND_API_KEY is NOT configured this way (see
# SETUP.md — it's a Secret Manager-backed param set via `firebase functions:secrets:set`).
# SITE_ORIGIN=https://your-custom-domain.example
