rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Editor image/circuit-diagram uploads: public read (post images render on public pages),
    // write requires an authenticated user. Post-level ownership is enforced by Firestore rules
    // on the post document itself; this keeps Storage rules simple since the temp post ID used
    // for the upload path may not correspond to a saved Firestore doc yet (decision #9).
    match /posts/{postId}/{fileName} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // Separate from create/update: `request.resource` is null on delete, so folding this into
      // the `write` rule above (which checks request.resource.size/contentType) would make deletes
      // always evaluate to false. Lets any authenticated user delete, matching the upload rule's
      // existing tradeoff (see decision #9) of not tracking per-uid ownership at the Storage layer.
      allow delete: if request.auth != null;
    }

    // Profile avatar/cover uploads (users/{uid}/avatar.<ext>, users/{uid}/cover.<ext>): public
    // read, write only by the uid whose folder it is.
    match /users/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
