# Firebase client SDK config (public — safe to expose to the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Toss Payments client key (public — safe to expose to the browser, same as the Firebase config
# above). Used for the reader→writer 응원(tip) feature (src/lib/support-client.ts). Get it from
# https://developers.tosspayments.com/my/api-keys — use a test key (`test_ck_...`) until the real
# merchant contract is approved. The matching secret key is NOT an env var — it's Secret
# Manager-backed for Cloud Functions, same pattern as RESEND_API_KEY:
#   firebase functions:secrets:set TOSS_SECRET_KEY
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# Firebase Admin SDK (server-only — NEVER prefix with NEXT_PUBLIC_, never commit real values)
# NOT used by the app itself (Server Components read Firestore via the plain client SDK — see
# src/lib/firebase/public.ts and SETUP.md §5). Only needed if you run the optional seed script
# (`npm run seed`, SETUP.md §3), which bypasses firestore.rules to write under a fake author.
# Generate at: Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
