rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isRealUser() {
      // "Real" = not the anonymous fallback identity every visitor gets for view-count dedup
      // (see src/context/auth-context.tsx). Comments/likes require this; view tracking doesn't.
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isVerifiedUser() {
      // Additionally requires a verified email (see functions/src/index.ts — we set this
      // ourselves via the Admin SDK after a custom Resend-based flow, never Firebase's own
      // built-in verification email; `email_verified` is a standard ID token claim that reflects
      // the Auth user record's `emailVerified` field for free once it's set). Used specifically
      // for *creating* new content (posts, comments, likes) — not for deleting/editing existing
      // content the user already owns, which stays gated on isRealUser() only.
      return isRealUser() && request.auth.token.email_verified == true;
    }

    // True if the caller has ever paid for a subscription to `authorId` whose paid-through date
    // hasn't passed yet — deliberately independent of `status` (see the Subscription type doc):
    // a cancelled-but-not-yet-expired subscription still grants access, per the confirmed
    // no-prorated-cutoff policy. Used to gate `posts/{postId}/premium/{doc}` below.
    function hasActiveAccess(authorId) {
      let subId = authorId + '_' + request.auth.uid;
      return isSignedIn()
        && exists(/databases/$(database)/documents/subscriptions/$(subId))
        && get(/databases/$(database)/documents/subscriptions/$(subId)).data.currentPeriodEnd > request.time;
    }

    // Posts: public read of published posts. Any authenticated user may create a post as
    // themselves (no admin/writer role distinction — see project brief decision #4). Only the
    // author may update or delete their own post, and may not reassign authorship. Denormalized
    // counters (commentCount/likeCount/viewCount) are the one exception: any authenticated user
    // (including anonymous, for view counts) may bump *only* those fields — the standard
    // Firestore pattern for counters touched by non-owners.
    match /posts/{postId} {
      // Single-doc get additionally allows the author to fetch their own draft directly by id
      // (status != 'published'); list queries stay published-only since Firestore can only
      // validate a list rule against filters the query itself already applies, and no query in
      // this app filters "my own drafts" yet (draft is create/save-only for now — no
      // browse-your-drafts UI).
      allow get: if resource.data.status == 'published'
        || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow list: if resource.data.status == 'published';

      allow create: if isVerifiedUser()
        && request.resource.data.authorId == request.auth.uid
        && (request.resource.data.status == 'published' || request.resource.data.status == 'draft');

      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId;

      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likeCount', 'commentCount', 'viewCount']);

      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      // Likes: presence of posts/{postId}/likes/{uid} means uid likes the post. Only the uid
      // named in the doc path may create/delete their own like, and only a real (non-anonymous)
      // account may like — same gating as comments.
      match /likes/{uid} {
        allow get, list: if true;
        // Liking (create) requires a verified email; unliking (delete) doesn't — only new-content
        // creation is gated on verification, per the project brief.
        allow create: if isVerifiedUser() && request.auth.uid == uid;
        allow delete: if isRealUser() && request.auth.uid == uid;
      }

      // 구독자 전용 (subscribers-only) posts store their real body here instead of on the parent
      // doc — see the Post.visibility doc comment in types.ts. This is the only place the actual
      // gated content lives, so it's the only place that needs the subscription check; the parent
      // post doc's existing get/list rules stay untouched and safe since they never hold the
      // gated content for a subscribers-only post in the first place.
      match /premium/{docId} {
        allow get: if isSignedIn()
          && (get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid
            || hasActiveAccess(get(/databases/$(database)/documents/posts/$(postId)).data.authorId));
        // Written by the author's own publish flow, right after the parent post doc itself is
        // created — see posts-client.ts.
        allow create, update: if isVerifiedUser()
          && get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid;
      }
    }

    // Users: public read of profile docs, owner-only write. Profile fields added for
    // avatar/cover/bio/handle/links are still owner-only, same principle as before.
    match /users/{uid} {
      allow get, list: if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Handles: `handles/{handle} -> { uid }` reserves an @handle for its owner. Handles are
    // immutable for v1 (no update/delete rule — see SETUP.md scope cut): once claimed, a handle
    // can never be released or transferred without a manual Console edit.
    match /handles/{handle} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // Comments (top-level collection, not a subcollection, so a single query can list every
    // comment for a post regardless of nesting — see the Comment type doc for the flattened
    // one-level-of-nesting UI). Only a real, non-anonymous signed-in user may comment as
    // themselves; only the author may delete their own comment (deleting a top-level comment's
    // replies is a client-side batch of individual deletes, each covered by this same rule).
    match /comments/{commentId} {
      allow get, list: if true;
      allow create: if isVerifiedUser() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isRealUser() && resource.data.authorId == request.auth.uid;
    }

    // Email verification tokens (`emailVerifications/{uid}` — see functions/src/index.ts):
    // Admin-SDK-only. Cloud Functions bypass these rules entirely, so this explicit deny-all is
    // defense-in-depth documentation, not something that changes real behavior — no client should
    // ever read/write this collection directly.
    match /emailVerifications/{uid} {
      allow read, write: if false;
    }

    // Reader→writer 응원(tip) records, one doc per payment attempt (doc id is the Toss orderId).
    // Only ever created here as 'pending' by the supporter; the confirmTossPayment Cloud Function
    // (Admin SDK, bypasses these rules) is the only thing that ever flips status to
    // 'paid'/'failed' once it's actually verified the payment with Toss — a client can never mark
    // its own payment as paid. No self-tipping. Fixed amount presets only, for now.
    match /supports/{orderId} {
      allow get: if isSignedIn()
        && (resource.data.supporterId == request.auth.uid || resource.data.authorId == request.auth.uid);
      allow create: if isVerifiedUser()
        && request.resource.data.supporterId == request.auth.uid
        && request.resource.data.authorId != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount in [1000, 3000, 5000, 10000];
    }

    // Reader→author paid subscriptions (`subscriptions/{authorId}_{subscriberId}`). Only ever
    // written by confirmSubscription/cancelSubscription/chargeActiveSubscriptions (Admin SDK,
    // bypasses these rules) — a client can read its own (either side of the subscription) but can
    // never create/update one directly, since that would let someone grant themselves access
    // without actually paying.
    match /subscriptions/{subId} {
      allow get: if isSignedIn()
        && (resource.data.subscriberId == request.auth.uid || resource.data.authorId == request.auth.uid);
    }

    // The actual Toss billing key for a subscription (`billingKeys/{authorId}_{subscriberId}`),
    // kept in a separate collection from `subscriptions` (deny-all, same pattern as
    // emailVerifications) so it's never even structurally reachable by a client read, unlike a
    // sensitive field living alongside otherwise-normal-to-read subscription metadata.
    match /billingKeys/{id} {
      allow read, write: if false;
    }

    // In-app notifications (`notifications/{uid}/items/{itemId}`), populated by Cloud Functions on
    // support payments, subscription events, and new subscriber-only posts — see the header's
    // notification bell. Owner can read their own and mark one read, nothing else.
    match /notifications/{uid}/items/{itemId} {
      allow get, list: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // Post views: `postViews/{postId}_{uid}` is a create-only dedup marker (no update/delete) —
    // unlike likes/comments, anonymous visitors are allowed here so guest traffic is still
    // counted. The doc id must match the uid making the request, so nobody can inflate another
    // visitor's view.
    match /postViews/{viewId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && viewId == request.resource.data.postId + '_' + request.auth.uid;
    }
  }
}
